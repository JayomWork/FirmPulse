@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div class="workspace-title">
                <div class="workspace-label">FirmPulse Workspace</div>
                <div class="workspace-caption">Practice management and compliance tracking for CS firms</div>
            </div>
            <div class="workspace-meta">
                <div class="workspace-chip">MVP Demo</div>
                <div class="workspace-user">
                    <span class="workspace-user-dot"></span>
                    Ready for client walkthrough
                </div>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>
