@page "/services"
@inject IServiceMasterService ServiceMasterService

<PageTitle>Service Catalog</PageTitle>

<div class="page-header">
    <div>
        <p class="eyebrow">Catalog</p>
        <h1>Service Catalog</h1>
        <p class="text-muted mb-0">Define the compliance and secretarial services your firm delivers.</p>
    </div>
</div>

@if (isLoading)
{
    <div class="alert alert-light border">Loading services...</div>
}
else
{
    <div class="row g-4">
        <div class="col-xl-4">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h2 class="h5 mb-0">@(isEditMode ? "Edit Service" : "Add Service")</h2>
                </div>
                <div class="card-body">
                    <EditForm Model="model" OnValidSubmit="SaveAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Category</label>
                            <InputSelect class="form-select" @bind-Value="model.ServiceCategoryId">
                                @foreach (var category in categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Service Code</label>
                            <InputText class="form-control" @bind-Value="model.ServiceCode" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Service Name</label>
                            <InputText class="form-control" @bind-Value="model.ServiceName" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputTextArea class="form-control" @bind-Value="model.Description" />
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Default Fee</label>
                                <InputNumber class="form-control" @bind-Value="model.DefaultFee" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Default Due Days</label>
                                <InputNumber class="form-control" @bind-Value="model.DefaultDueDays" />
                            </div>
                        </div>
                        <div class="mt-3">
                            <div class="form-check">
                                <InputCheckbox class="form-check-input" @bind-Value="model.IsRecurring" />
                                <label class="form-check-label ms-2">Recurring Service</label>
                            </div>
                        </div>
                        <div class="mb-3 mt-3">
                            <label class="form-label">Recurring Type</label>
                            <InputSelect class="form-select" @bind-Value="model.RecurringType">
                                <option value="">Select recurring type</option>
                                @foreach (var recurringType in ServiceRecurringTypes.All)
                                {
                                    <option value="@recurringType">@recurringType</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="form-check mb-3">
                            <InputCheckbox class="form-check-input" @bind-Value="model.IsActive" />
                            <label class="form-check-label ms-2">Active</label>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Save Service</button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="ResetForm">Cancel</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

        <div class="col-xl-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white"><h2 class="h5 mb-0">Category and Service List</h2></div>
                <div class="card-body">
                    @foreach (var category in categories)
                    {
                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h3 class="h6 mb-1">@category.Name</h3>
                                    <p class="text-muted mb-0">@category.Description</p>
                                </div>
                                <span class="badge bg-secondary-subtle text-secondary-emphasis">@category.Services.Count active items</span>
                            </div>
                            @if (category.Services.Count == 0)
                            {
                                <div class="text-muted small">No services mapped to this category yet.</div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-0">
                                        <thead class="table-light">
                                            <tr><th>Service</th><th>Recurring</th><th>Default Fee</th><th></th></tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var service in category.Services.OrderBy(x => x.ServiceName))
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="fw-semibold">@service.ServiceName</div>
                                                        <div class="small text-muted">@service.ServiceCode</div>
                                                    </td>
                                                    <td>@(service.IsRecurring ? service.RecurringType : "Event Based")</td>
                                                    <td>@(service.DefaultFee.HasValue ? CurrencyHelper.ToInr(service.DefaultFee.Value) : "-")</td>
                                                    <td class="text-end"><button class="btn btn-sm btn-outline-primary" @onclick="@(() => EditService(service.Id))">Edit</button></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ServiceCategory> categories = [];
    private List<ServiceMaster> services = [];
    private ServiceMaster model = new() { IsActive = true };
    private bool isLoading = true;
    private bool isEditMode;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        categories = await ServiceMasterService.GetCategoriesAsync();
        services = await ServiceMasterService.GetServicesAsync();
        if (!isEditMode && categories.Count > 0 && model.ServiceCategoryId == 0)
        {
            model.ServiceCategoryId = categories[0].Id;
        }

        isLoading = false;
    }

    private async Task SaveAsync()
    {
        if (isEditMode)
        {
            await ServiceMasterService.UpdateServiceAsync(model);
        }
        else
        {
            await ServiceMasterService.CreateServiceAsync(model);
        }

        ResetForm();
        await LoadAsync();
    }

    private void EditService(int id)
    {
        var existing = services.First(x => x.Id == id);
        model = new ServiceMaster
        {
            Id = existing.Id,
            ServiceCategoryId = existing.ServiceCategoryId,
            ServiceCode = existing.ServiceCode,
            ServiceName = existing.ServiceName,
            Description = existing.Description,
            DefaultFee = existing.DefaultFee,
            DefaultDueDays = existing.DefaultDueDays,
            IsRecurring = existing.IsRecurring,
            RecurringType = existing.RecurringType,
            IsActive = existing.IsActive
        };
        isEditMode = true;
    }

    private void ResetForm()
    {
        model = new ServiceMaster
        {
            ServiceCategoryId = categories.FirstOrDefault()?.Id ?? 0,
            IsActive = true,
            IsRecurring = true,
            RecurringType = ServiceRecurringTypes.Yearly
        };
        isEditMode = false;
    }
}
