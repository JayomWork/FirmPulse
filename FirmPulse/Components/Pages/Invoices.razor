@page "/invoices"
@inject IInvoiceService InvoiceService
@inject NavigationManager NavigationManager

<PageTitle>Invoices</PageTitle>

<div class="page-header">
    <div>
        <p class="eyebrow">Billing</p>
        <h1>Invoices</h1>
        <p class="text-muted mb-0">Track billing status, due dates, and outstanding balances.</p>
    </div>
    <button class="btn btn-primary" @onclick="CreateInvoice">Add Invoice</button>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (isLoading)
        {
            <div class="p-4 text-muted">Loading invoices...</div>
        }
        else if (invoices.Count == 0)
        {
            <div class="p-4 text-muted">No invoices created yet.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Invoice</th>
                            <th>Company</th>
                            <th>Amount</th>
                            <th>Total</th>
                            <th>Due Date</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var invoice in invoices)
                        {
                            <tr>
                                <td class="fw-semibold">@invoice.InvoiceNumber</td>
                                <td>@invoice.CompanyClient?.CompanyName</td>
                                <td>@CurrencyHelper.ToInr(invoice.Amount)</td>
                                <td>@CurrencyHelper.ToInr(invoice.TotalAmount)</td>
                                <td>@invoice.DueDate.ToString("dd MMM yyyy")</td>
                                <td><span class="badge @BadgeHelper.GetInvoiceStatusBadge(invoice.Status)">@invoice.Status</span></td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="@(() => EditInvoice(invoice.Id))">Edit</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<Invoice> invoices = [];
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        invoices = await InvoiceService.GetAllAsync();
        isLoading = false;
    }

    private void CreateInvoice() => NavigationManager.NavigateTo("/invoices/create");

    private void EditInvoice(int id) => NavigationManager.NavigateTo($"/invoices/edit/{id}");
}
