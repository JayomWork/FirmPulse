@page "/companies"
@inject ICompanyClientService CompanyClientService
@inject NavigationManager NavigationManager

<PageTitle>Companies</PageTitle>

<div class="page-header">
    <div>
        <p class="eyebrow">Clients</p>
        <h1>Companies</h1>
        <p class="text-muted mb-0">Manage your active company clients and their core details.</p>
    </div>
    <button class="btn btn-primary" @onclick="CreateCompany">Add Company</button>
</div>

<div class="card shadow-sm">
    <div class="card-body border-bottom">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Search</label>
                <InputText class="form-control" @bind-Value="searchTerm" placeholder="Search by company name, CIN, or PAN" />
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        @if (isLoading)
        {
            <div class="p-4 text-muted">Loading companies...</div>
        }
        else if (FilteredCompanies.Count == 0)
        {
            <div class="p-4 text-muted">No active companies found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Company</th>
                            <th>CIN</th>
                            <th>Contact</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var company in FilteredCompanies)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@company.CompanyName</div>
                                    <div class="small text-muted">@company.CompanyType</div>
                                </td>
                                <td>@company.CIN</td>
                                <td>
                                    <div>@company.ContactPersonName</div>
                                    <div class="small text-muted">@company.Email</div>
                                </td>
                                <td><span class="badge bg-success-subtle text-success-emphasis">@company.Status</span></td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-secondary" @onclick="@(() => ViewCompany(company.Id))">View</button>
                                        <button class="btn btn-outline-primary" @onclick="@(() => EditCompany(company.Id))">Edit</button>
                                        <button class="btn btn-outline-danger" @onclick="@(() => DeleteCompanyAsync(company.Id))">Delete</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<CompanyClient> companies = [];
    private bool isLoading = true;
    private string searchTerm = string.Empty;

    private List<CompanyClient> FilteredCompanies =>
        companies.Where(company =>
            string.IsNullOrWhiteSpace(searchTerm) ||
            company.CompanyName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            (company.CIN?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (company.PAN?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadCompaniesAsync();
    }

    private async Task LoadCompaniesAsync()
    {
        isLoading = true;
        companies = await CompanyClientService.GetAllAsync();
        isLoading = false;
    }

    private void ViewCompany(int id) => NavigationManager.NavigateTo($"/companies/{id}");

    private void EditCompany(int id) => NavigationManager.NavigateTo($"/companies/edit/{id}");

    private void CreateCompany() => NavigationManager.NavigateTo("/companies/create");

    private async Task DeleteCompanyAsync(int id)
    {
        await CompanyClientService.DeleteAsync(id);
        await LoadCompaniesAsync();
    }
}
