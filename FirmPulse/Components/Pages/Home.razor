@page "/"
@inject IDashboardService DashboardService

<PageTitle>Dashboard</PageTitle>

<div class="page-header">
    <div>
        <p class="eyebrow">CS Control Center</p>
        <h1>Firm Dashboard</h1>
        <p class="text-muted mb-0">A practical daily view for client commitments, filings, meetings, and billing.</p>
    </div>
</div>

@if (isLoading)
{
    <div class="alert alert-light border">Loading dashboard...</div>
}
else
{
    <div class="dashboard-hero mb-4">
        <div>
            <p class="eyebrow mb-2">Today at a glance</p>
            <h2 class="dashboard-hero-title">Stay ahead of filings, meetings, and client follow-ups.</h2>
            <p class="dashboard-hero-text mb-0">FirmPulse brings recurring compliance, event-based work, document collection, and invoice exposure into one standard client-ready workspace.</p>
        </div>
        <div class="dashboard-hero-panel">
            <div class="dashboard-hero-stat">
                <span>Due this week</span>
                <strong>@summary.DueThisWeekCount work items</strong>
            </div>
            <div class="dashboard-hero-stat">
                <span>Unpaid invoices</span>
                <strong>@CurrencyHelper.ToInr(summary.UnpaidInvoiceTotal)</strong>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="card metric-card h-100"><div class="card-body"><p class="metric-label">Active Companies</p><h2>@summary.TotalActiveCompanies</h2></div></div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card metric-card h-100"><div class="card-body"><p class="metric-label">Due This Week</p><h2>@summary.DueThisWeekCount</h2></div></div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card metric-card h-100"><div class="card-body"><p class="metric-label">Due This Month</p><h2>@summary.DueThisMonthCount</h2></div></div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card metric-card h-100"><div class="card-body"><p class="metric-label">Overdue Work</p><h2 class="text-danger">@summary.OverdueWorkItemsCount</h2></div></div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card metric-card h-100"><div class="card-body"><p class="metric-label">Pending Client Documents</p><h2>@summary.PendingClientDocumentsCount</h2></div></div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card metric-card h-100"><div class="card-body"><p class="metric-label">Pending MCA Filings</p><h2>@summary.PendingMcaFilingsCount</h2></div></div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card metric-card h-100"><div class="card-body"><p class="metric-label">Filed This Month</p><h2>@summary.FiledThisMonthCount</h2></div></div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card metric-card h-100"><div class="card-body"><p class="metric-label">Upcoming AGM</p><h2>@summary.UpcomingAgmCount</h2></div></div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card metric-card h-100"><div class="card-body"><p class="metric-label">Upcoming Board Meetings</p><h2>@summary.UpcomingBoardMeetingCount</h2></div></div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card metric-card h-100"><div class="card-body"><p class="metric-label">Unpaid Invoice Total</p><h2>@CurrencyHelper.ToInr(summary.UnpaidInvoiceTotal)</h2></div></div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12">
            <div class="card dashboard-panel">
                <div class="card-header bg-white"><h3 class="h5 mb-0">Upcoming Work Items</h3></div>
                <div class="card-body p-0">@RenderWorkItemTable(upcomingWorkItems, "No work items due in the next 30 days.")</div>
            </div>
        </div>
        <div class="col-xl-6">
            <div class="card dashboard-panel h-100">
                <div class="card-header bg-white"><h3 class="h5 mb-0">Overdue Work Items</h3></div>
                <div class="card-body p-0">@RenderWorkItemTable(overdueWorkItems, "No overdue work items right now.")</div>
            </div>
        </div>
        <div class="col-xl-6">
            <div class="card dashboard-panel h-100">
                <div class="card-header bg-white"><h3 class="h5 mb-0">Pending Client Documents</h3></div>
                <div class="card-body p-0">@RenderWorkItemTable(pendingDocumentWorkItems, "No pending client document follow-ups.")</div>
            </div>
        </div>
        <div class="col-12">
            <div class="card dashboard-panel">
                <div class="card-header bg-white"><h3 class="h5 mb-0">Upcoming Meetings</h3></div>
                <div class="card-body p-0">
                    @if (upcomingMeetings.Count == 0)
                    {
                        <div class="p-4 text-muted">No meetings are currently scheduled for the next 30 days.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Meeting</th>
                                        <th>Company</th>
                                        <th>Meeting Date</th>
                                        <th>Mode / Venue</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var meeting in upcomingMeetings)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@meeting.Title</div>
                                                <div class="small text-muted">@meeting.MeetingType</div>
                                            </td>
                                            <td>@meeting.CompanyClient?.CompanyName</td>
                                            <td>@FormatDate(meeting.MeetingDate)</td>
                                            <td>@meeting.VenueOrMode</td>
                                            <td><span class="badge @BadgeHelper.GetMeetingStatusBadge(meeting.Status)">@meeting.Status</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private CsDashboardSummaryModel summary = new();
    private List<WorkItem> upcomingWorkItems = [];
    private List<WorkItem> overdueWorkItems = [];
    private List<WorkItem> pendingDocumentWorkItems = [];
    private List<CompanyMeeting> upcomingMeetings = [];
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        summary = await DashboardService.GetCsDashboardSummaryAsync();
        upcomingWorkItems = await DashboardService.GetUpcomingWorkItemsAsync();
        overdueWorkItems = await DashboardService.GetOverdueWorkItemsAsync();
        pendingDocumentWorkItems = await DashboardService.GetPendingDocumentWorkItemsAsync();
        upcomingMeetings = await DashboardService.GetUpcomingMeetingsAsync();
        isLoading = false;
    }

    private RenderFragment RenderWorkItemTable(List<WorkItem> items, string emptyMessage) => builder =>
    {
        if (items.Count == 0)
        {
            builder.OpenElement(0, "div");
            builder.AddAttribute(1, "class", "p-4 text-muted");
            builder.AddContent(2, emptyMessage);
            builder.CloseElement();
            return;
        }

        builder.OpenElement(3, "div");
        builder.AddAttribute(4, "class", "table-responsive");
        builder.AddMarkupContent(5, "<table class=\"table table-hover align-middle mb-0\"><thead class=\"table-light\"><tr><th>Work Item</th><th>Company</th><th>Due Date</th><th>Status</th><th>Next Best Action</th></tr></thead><tbody>");
        var seq = 6;
        foreach (var item in items)
        {
            builder.AddMarkupContent(seq++, "<tr>");
            builder.AddMarkupContent(seq++, $"<td><div class=\"fw-semibold\">{item.Title}</div><div class=\"small text-muted\">{item.McaFormMaster?.FormCode ?? item.ServiceMaster?.ServiceName ?? item.FinancialYear}</div></td>");
            builder.AddMarkupContent(seq++, $"<td>{item.CompanyClient?.CompanyName}</td>");
            builder.AddMarkupContent(seq++, $"<td>{FormatDate(item.DueDate)}</td>");
            builder.AddMarkupContent(seq++, $"<td><span class=\"badge {BadgeHelper.GetWorkItemStatusBadge(WorkItemHelper.GetDisplayStatus(item))}\">{WorkItemHelper.GetDisplayStatus(item)}</span></td>");
            builder.AddMarkupContent(seq++, $"<td>{WorkItemHelper.GetNextBestAction(item)}</td>");
            builder.AddMarkupContent(seq++, "</tr>");
        }

        builder.AddMarkupContent(seq, "</tbody></table></div>");
        builder.CloseElement();
    };

    private static string FormatDate(DateOnly? value) => value?.ToString("dd MMM yyyy") ?? "-";
}
