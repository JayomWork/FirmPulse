@page "/companies/create"
@page "/companies/edit/{Id:int}"
@inject ICompanyClientService CompanyClientService
@inject FirmPulseDbContext DbContext
@inject NavigationManager NavigationManager

<PageTitle>@(IsEditMode ? "Edit Company" : "Add Company")</PageTitle>

<div class="page-header">
    <div>
        <p class="eyebrow">Clients</p>
        <h1>@(IsEditMode ? "Edit Company" : "Add Company")</h1>
        <p class="text-muted mb-0">Capture the key legal and contact information for a company client.</p>
    </div>
</div>

@if (isLoading)
{
    <div class="alert alert-light border">Loading company form...</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <EditForm Model="model" OnValidSubmit="SaveAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Company Name</label>
                        <InputText class="form-control" @bind-Value="model.CompanyName" />
                        <ValidationMessage For="@(() => model.CompanyName)" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">CIN / LLPIN</label>
                        <InputText class="form-control" @bind-Value="model.CIN" />
                        <ValidationMessage For="@(() => model.CIN)" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">PAN</label>
                        <InputText class="form-control" @bind-Value="model.PAN" />
                        <ValidationMessage For="@(() => model.PAN)" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Incorporation Date</label>
                        <InputDate class="form-control" @bind-Value="model.IncorporationDate" />
                        <ValidationMessage For="@(() => model.IncorporationDate)" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Company Type</label>
                        <InputSelect class="form-select" @bind-Value="model.CompanyType">
                            @foreach (var companyType in CompanyClientTypes.All)
                            {
                                <option value="@companyType">@companyType</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => model.CompanyType)" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Status</label>
                        <InputSelect class="form-select" @bind-Value="model.Status">
                            @foreach (var status in CompanyClientStatuses.All)
                            {
                                <option value="@status">@status</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => model.Status)" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Company Class</label>
                        <InputText class="form-control" @bind-Value="model.CompanyClass" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Registration Number</label>
                        <InputText class="form-control" @bind-Value="model.RegistrationNumber" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">City</label>
                        <InputText class="form-control" @bind-Value="model.City" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">State</label>
                        <InputText class="form-control" @bind-Value="model.State" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Pin Code</label>
                        <InputText class="form-control" @bind-Value="model.PinCode" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">FY End Month</label>
                        <InputNumber class="form-control" @bind-Value="model.FinancialYearEndMonth" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">FY End Day</label>
                        <InputNumber class="form-control" @bind-Value="model.FinancialYearEndDay" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Last AGM Date</label>
                        <InputDate class="form-control" @bind-Value="model.LastAGMDate" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Financial Year Start</label>
                        <InputDate class="form-control" @bind-Value="model.FinancialYearStart" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Financial Year End</label>
                        <InputDate class="form-control" @bind-Value="model.FinancialYearEnd" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Authorized Capital</label>
                        <InputNumber class="form-control" @bind-Value="model.AuthorizedCapital" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Paid-up Capital</label>
                        <InputNumber class="form-control" @bind-Value="model.PaidUpCapital" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <InputText class="form-control" @bind-Value="model.Email" />
                        <ValidationMessage For="@(() => model.Email)" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Phone</label>
                        <InputText class="form-control" @bind-Value="model.Phone" />
                        <ValidationMessage For="@(() => model.Phone)" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Contact Person Name</label>
                        <InputText class="form-control" @bind-Value="model.ContactPersonName" />
                        <ValidationMessage For="@(() => model.ContactPersonName)" />
                    </div>
                    <div class="col-md-3">
                        <div class="form-check mt-4 pt-2">
                            <InputCheckbox class="form-check-input" @bind-Value="model.IsListed" />
                            <label class="form-check-label ms-2">Listed Company</label>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-check mt-4 pt-2">
                            <InputCheckbox class="form-check-input" @bind-Value="model.HasShareCapital" />
                            <label class="form-check-label ms-2">Has Share Capital</label>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">Registered Office Address</label>
                        <InputTextArea class="form-control" @bind-Value="model.RegisteredOfficeAddress" />
                        <ValidationMessage For="@(() => model.RegisteredOfficeAddress)" />
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">Save Company</button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">Cancel</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public int? Id { get; set; }

    private CompanyClient model = new();
    private bool isLoading = true;
    private int defaultFirmId;

    private bool IsEditMode => Id.HasValue;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        defaultFirmId = await DbContext.Firms.Select(x => x.Id).FirstAsync();

        if (IsEditMode)
        {
            model = await CompanyClientService.GetByIdAsync(Id!.Value) ?? new CompanyClient();
        }
        else
        {
            model = new CompanyClient
            {
                FirmId = defaultFirmId,
                Status = CompanyClientStatuses.Active,
                CompanyType = CompanyClientTypes.PrivateLimited,
                CompanyClass = "Private Company Limited by Shares",
                FinancialYearEndMonth = 3,
                FinancialYearEndDay = 31,
                FinancialYearStart = new DateOnly(DateTime.Today.Month >= 4 ? DateTime.Today.Year : DateTime.Today.Year - 1, 4, 1),
                FinancialYearEnd = new DateOnly(DateTime.Today.Month >= 4 ? DateTime.Today.Year + 1 : DateTime.Today.Year, 3, 31),
                HasShareCapital = true
            };
        }

        isLoading = false;
    }

    private async Task SaveAsync()
    {
        model.FirmId = defaultFirmId;

        if (IsEditMode)
        {
            await CompanyClientService.UpdateAsync(model);
        }
        else
        {
            await CompanyClientService.CreateAsync(model);
        }

        NavigationManager.NavigateTo("/companies");
    }

    private void Cancel() => NavigationManager.NavigateTo("/companies");
}
