@page "/companies/{Id:int}"
@inject ICompanyClientService CompanyClientService
@inject NavigationManager NavigationManager

<PageTitle>Company Detail</PageTitle>

@if (isLoading)
{
    <div class="alert alert-light border">Loading company details...</div>
}
else if (company is null)
{
    <div class="alert alert-warning">The requested company could not be found.</div>
}
else
{
    <div class="page-header">
        <div>
            <p class="eyebrow">Company Workspace</p>
            <h1>@company.CompanyName</h1>
            <p class="text-muted mb-0">@company.CompanyType | @company.Status | @company.CompanyClass</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" @onclick="OpenPlans">Compliance Plans</button>
            <button class="btn btn-primary" @onclick="EditCompany">Edit Company</button>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white"><h2 class="h5 mb-0">Overview</h2></div>
                <div class="card-body">
                    <dl class="row detail-list mb-0">
                        <dt class="col-sm-5">CIN</dt><dd class="col-sm-7">@ValueOrDash(company.CIN)</dd>
                        <dt class="col-sm-5">PAN</dt><dd class="col-sm-7">@ValueOrDash(company.PAN)</dd>
                        <dt class="col-sm-5">Email</dt><dd class="col-sm-7">@ValueOrDash(company.Email)</dd>
                        <dt class="col-sm-5">Phone</dt><dd class="col-sm-7">@ValueOrDash(company.Phone)</dd>
                        <dt class="col-sm-5">Contact</dt><dd class="col-sm-7">@ValueOrDash(company.ContactPersonName)</dd>
                        <dt class="col-sm-5">Incorporated</dt><dd class="col-sm-7">@FormatDate(company.IncorporationDate)</dd>
                        <dt class="col-sm-5">Last AGM</dt><dd class="col-sm-7">@FormatDate(company.LastAGMDate)</dd>
                        <dt class="col-sm-5">FY End</dt><dd class="col-sm-7">@FormatFyEnd(company)</dd>
                        <dt class="col-sm-5">Listed</dt><dd class="col-sm-7">@(company.IsListed ? "Yes" : "No")</dd>
                        <dt class="col-sm-5">Share Capital</dt><dd class="col-sm-7">@(company.HasShareCapital ? "Yes" : "No")</dd>
                        <dt class="col-sm-5">Registered Office</dt><dd class="col-sm-7">@ValueOrDash(company.RegisteredOfficeAddress)</dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-xl-8">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="card metric-card h-100"><div class="card-body"><p class="metric-label">Plans</p><h2>@company.CompanyCompliancePlans.Count</h2></div></div>
                </div>
                <div class="col-md-4">
                    <div class="card metric-card h-100"><div class="card-body"><p class="metric-label">Open Work Items</p><h2>@OpenWorkItemCount</h2></div></div>
                </div>
                <div class="col-md-4">
                    <div class="card metric-card h-100"><div class="card-body"><p class="metric-label">Upcoming Meetings</p><h2>@UpcomingMeetingCount</h2></div></div>
                </div>
                <div class="col-md-6">
                    <div class="card metric-card h-100"><div class="card-body"><p class="metric-label">Pending Filings</p><h2>@PendingFilingCount</h2></div></div>
                </div>
                <div class="col-md-6">
                    <div class="card metric-card h-100"><div class="card-body"><p class="metric-label">Open Follow-Ups</p><h2>@OpenFollowUpCount</h2></div></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h2 class="h5 mb-0">Compliance Plans</h2>
                    <button class="btn btn-sm btn-outline-primary" @onclick="OpenPlans">Manage Plans</button>
                </div>
                <div class="card-body p-0">
                    @if (company.CompanyCompliancePlans.Count == 0)
                    {
                        <div class="p-4 text-muted">No compliance plans created yet. Start with a financial year plan for this company.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead class="table-light">
                                    <tr><th>Plan</th><th>Financial Year</th><th>Template</th><th>Status</th><th>Work Items</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var plan in company.CompanyCompliancePlans.OrderByDescending(x => x.FinancialYear))
                                    {
                                        <tr>
                                            <td>@plan.PlanName</td>
                                            <td>@plan.FinancialYear</td>
                                            <td>@plan.ComplianceTemplate?.TemplateName</td>
                                            <td><span class="badge bg-secondary-subtle text-secondary-emphasis">@plan.Status</span></td>
                                            <td>@company.WorkItems.Count(x => x.CompanyCompliancePlanId == plan.Id)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white"><h2 class="h5 mb-0">Work Items</h2></div>
                <div class="card-body p-0">
                    @if (company.WorkItems.Count == 0)
                    {
                        <div class="p-4 text-muted">No work items generated yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead class="table-light">
                                    <tr><th>Work Item</th><th>Due Date</th><th>Status</th><th>Next Action</th><th></th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var workItem in company.WorkItems.OrderBy(x => x.DueDate))
                                    {
                                        var displayStatus = WorkItemHelper.GetDisplayStatus(workItem);
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@workItem.Title</div>
                                                <div class="small text-muted">@workItem.McaFormMaster?.FormCode</div>
                                            </td>
                                            <td>@FormatDate(workItem.DueDate)</td>
                                            <td><span class="badge @BadgeHelper.GetWorkItemStatusBadge(displayStatus)">@displayStatus</span></td>
                                            <td>@WorkItemHelper.GetNextBestAction(workItem)</td>
                                            <td class="text-end"><a class="btn btn-sm btn-outline-primary" href="/work-items/@workItem.Id">Open</a></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white"><h2 class="h5 mb-0">Filing Register</h2></div>
                <div class="card-body p-0">
                    @if (company.FilingRecords.Count == 0)
                    {
                        <div class="p-4 text-muted">No filing records linked yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead class="table-light">
                                    <tr><th>Form</th><th>FY</th><th>Due</th><th>Status</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var filing in company.FilingRecords.OrderBy(x => x.DueDate))
                                    {
                                        <tr>
                                            <td>@filing.McaFormMaster?.FormCode</td>
                                            <td>@filing.FinancialYear</td>
                                            <td>@FormatDate(filing.DueDate)</td>
                                            <td><span class="badge @BadgeHelper.GetFilingStatusBadge(filing.McaStatus)">@filing.McaStatus</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white"><h2 class="h5 mb-0">Meetings</h2></div>
                <div class="card-body p-0">
                    @if (company.CompanyMeetings.Count == 0)
                    {
                        <div class="p-4 text-muted">No meetings scheduled yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead class="table-light">
                                    <tr><th>Meeting</th><th>Date</th><th>Status</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var meeting in company.CompanyMeetings.OrderBy(x => x.MeetingDate))
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@meeting.Title</div>
                                                <div class="small text-muted">@meeting.MeetingType</div>
                                            </td>
                                            <td>@FormatDate(meeting.MeetingDate)</td>
                                            <td><span class="badge @BadgeHelper.GetMeetingStatusBadge(meeting.Status)">@meeting.Status</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white"><h2 class="h5 mb-0">Directors</h2></div>
                <div class="card-body p-0">
                    @if (company.Directors.Count == 0)
                    {
                        <div class="p-4 text-muted">No directors recorded yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead class="table-light">
                                    <tr><th>Name</th><th>DIN</th><th>Appointment</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var director in company.Directors)
                                    {
                                        <tr>
                                            <td>@director.FullName</td>
                                            <td>@director.DIN</td>
                                            <td>@FormatDate(director.AppointmentDate)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white"><h2 class="h5 mb-0">Follow-Ups</h2></div>
                <div class="card-body p-0">
                    @if (company.ClientFollowUps.Count == 0)
                    {
                        <div class="p-4 text-muted">No follow-up history recorded yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead class="table-light">
                                    <tr><th>Date</th><th>Subject</th><th>Type</th><th>Status</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var followUp in company.ClientFollowUps.OrderByDescending(x => x.FollowUpDate))
                                    {
                                        <tr>
                                            <td>@followUp.FollowUpDate.ToString("dd MMM yyyy")</td>
                                            <td>@followUp.Subject</td>
                                            <td>@followUp.FollowUpType</td>
                                            <td><span class="badge @BadgeHelper.GetFollowUpStatusBadge(followUp.Status)">@followUp.Status</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white"><h2 class="h5 mb-0">Documents</h2></div>
                <div class="card-body p-0">
                    @if (company.DocumentRecords.Count == 0)
                    {
                        <div class="p-4 text-muted">No standalone company documents have been uploaded yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead class="table-light">
                                    <tr><th>Name</th><th>Type</th><th>Uploaded</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var document in company.DocumentRecords)
                                    {
                                        <tr>
                                            <td>@document.DocumentName</td>
                                            <td>@document.DocumentType</td>
                                            <td>@document.UploadedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white"><h2 class="h5 mb-0">Invoices</h2></div>
                <div class="card-body p-0">
                    @if (company.Invoices.Count == 0)
                    {
                        <div class="p-4 text-muted">No invoices created yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead class="table-light">
                                    <tr><th>Invoice</th><th>Total</th><th>Unpaid</th><th>Status</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var invoice in company.Invoices.Where(x => x.IsActive).OrderByDescending(x => x.InvoiceDate))
                                    {
                                        var unpaidAmount = Math.Max(0m, invoice.TotalAmount - invoice.Payments.Sum(x => x.Amount));
                                        <tr>
                                            <td>@invoice.InvoiceNumber</td>
                                            <td>@CurrencyHelper.ToInr(invoice.TotalAmount)</td>
                                            <td>@CurrencyHelper.ToInr(unpaidAmount)</td>
                                            <td><span class="badge @BadgeHelper.GetInvoiceStatusBadge(invoice.Status)">@invoice.Status</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private CompanyClient? company;
    private bool isLoading = true;

    private int OpenWorkItemCount => company?.WorkItems.Count(x => x.Status is not WorkItemStatuses.Completed and not WorkItemStatuses.Cancelled and not WorkItemStatuses.Filed) ?? 0;
    private int PendingFilingCount => company?.FilingRecords.Count(x => x.McaStatus is not FilingRecordStatuses.Approved and not FilingRecordStatuses.Filed) ?? 0;
    private int OpenFollowUpCount => company?.ClientFollowUps.Count(x => x.Status != ClientFollowUpStatuses.Done) ?? 0;
    private int UpcomingMeetingCount => company?.CompanyMeetings.Count(x => x.MeetingDate >= DateOnly.FromDateTime(DateTime.Today)) ?? 0;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        company = await CompanyClientService.GetByIdAsync(Id);
        isLoading = false;
    }

    private void EditCompany()
    {
        if (company is not null)
        {
            NavigationManager.NavigateTo($"/companies/edit/{company.Id}");
        }
    }

    private void OpenPlans()
    {
        if (company is not null)
        {
            NavigationManager.NavigateTo($"/companies/{company.Id}/compliance-plans");
        }
    }

    private static string FormatDate(DateOnly? value) => value?.ToString("dd MMM yyyy") ?? "-";
    private static string ValueOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;
    private static string FormatFyEnd(CompanyClient company) => company.FinancialYearEndMonth.HasValue && company.FinancialYearEndDay.HasValue
        ? $"{company.FinancialYearEndDay:00}/{company.FinancialYearEndMonth:00}"
        : "-";
}
