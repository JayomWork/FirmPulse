@page "/companies/{Id:int}"
@inject ICompanyClientService CompanyClientService
@inject NavigationManager NavigationManager

<PageTitle>Company Detail</PageTitle>

@if (isLoading)
{
    <div class="alert alert-light border">Loading company details...</div>
}
else if (company is null)
{
    <div class="alert alert-warning">The requested company could not be found.</div>
}
else
{
    <div class="page-header">
        <div>
            <p class="eyebrow">Company Overview</p>
            <h1>@company.CompanyName</h1>
            <p class="text-muted mb-0">@company.CompanyType • @company.Status</p>
        </div>
        <button class="btn btn-outline-primary" @onclick="EditCompany">Edit Company</button>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white">
                    <h2 class="h5 mb-0">Company Information</h2>
                </div>
                <div class="card-body">
                    <dl class="row detail-list mb-0">
                        <dt class="col-sm-5">CIN</dt>
                        <dd class="col-sm-7">@company.CIN</dd>
                        <dt class="col-sm-5">PAN</dt>
                        <dd class="col-sm-7">@company.PAN</dd>
                        <dt class="col-sm-5">Contact Person</dt>
                        <dd class="col-sm-7">@company.ContactPersonName</dd>
                        <dt class="col-sm-5">Email</dt>
                        <dd class="col-sm-7">@company.Email</dd>
                        <dt class="col-sm-5">Phone</dt>
                        <dd class="col-sm-7">@company.Phone</dd>
                        <dt class="col-sm-5">Incorporated</dt>
                        <dd class="col-sm-7">@company.IncorporationDate?.ToString("dd MMM yyyy")</dd>
                        <dt class="col-sm-5">Registered Office</dt>
                        <dd class="col-sm-7">@company.RegisteredOfficeAddress</dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h2 class="h5 mb-0">Directors</h2>
                </div>
                <div class="card-body p-0">
                    @if (company.Directors.Count == 0)
                    {
                        <div class="p-4 text-muted">No directors recorded yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Name</th>
                                        <th>DIN</th>
                                        <th>Appointment</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var director in company.Directors)
                                    {
                                        <tr>
                                            <td>@director.FullName</td>
                                            <td>@director.DIN</td>
                                            <td>@director.AppointmentDate?.ToString("dd MMM yyyy")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h2 class="h5 mb-0">Compliance Tasks</h2>
                </div>
                <div class="card-body p-0">
                    @if (company.ComplianceTasks.Count == 0)
                    {
                        <div class="p-4 text-muted">No compliance tasks assigned yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Task</th>
                                        <th>Due Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var task in company.ComplianceTasks.OrderBy(x => x.DueDate))
                                    {
                                        var status = ComplianceTaskHelper.GetDisplayStatus(task);
                                        <tr>
                                            <td>@task.Title</td>
                                            <td>@task.DueDate.ToString("dd MMM yyyy")</td>
                                            <td><span class="badge @BadgeHelper.GetTaskStatusBadge(status)">@status</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h2 class="h5 mb-0">Documents</h2>
                </div>
                <div class="card-body">
                    @if (company.DocumentRecords.Count == 0)
                    {
                        <div class="text-muted">Document management is ready for extension. No documents uploaded in this MVP seed.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Name</th>
                                        <th>Type</th>
                                        <th>Uploaded</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var document in company.DocumentRecords)
                                    {
                                        <tr>
                                            <td>@document.DocumentName</td>
                                            <td>@document.DocumentType</td>
                                            <td>@document.UploadedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h2 class="h5 mb-0">Invoices</h2>
                </div>
                <div class="card-body p-0">
                    @if (company.Invoices.Count == 0)
                    {
                        <div class="p-4 text-muted">No invoices created yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Invoice</th>
                                        <th>Total</th>
                                        <th>Unpaid</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var invoice in company.Invoices.OrderByDescending(x => x.InvoiceDate))
                                    {
                                        var unpaidAmount = Math.Max(0m, invoice.TotalAmount - invoice.Payments.Sum(x => x.Amount));
                                        <tr>
                                            <td>@invoice.InvoiceNumber</td>
                                            <td>@CurrencyHelper.ToInr(invoice.TotalAmount)</td>
                                            <td>@CurrencyHelper.ToInr(unpaidAmount)</td>
                                            <td><span class="badge @BadgeHelper.GetInvoiceStatusBadge(invoice.Status)">@invoice.Status</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private CompanyClient? company;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        company = await CompanyClientService.GetByIdAsync(Id);
        isLoading = false;
    }

    private void EditCompany()
    {
        if (company is not null)
        {
            NavigationManager.NavigateTo($"/companies/edit/{company.Id}");
        }
    }
}
