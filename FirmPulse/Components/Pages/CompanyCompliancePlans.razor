@page "/companies/{CompanyId:int}/compliance-plans"
@inject ICompanyClientService CompanyClientService
@inject ICompanyCompliancePlanService CompanyCompliancePlanService
@inject IComplianceTemplateService ComplianceTemplateService
@inject IJSRuntime JS

<PageTitle>Company Compliance Plans</PageTitle>

<div class="page-header">
    <div>
        <p class="eyebrow">Company Planning</p>
        <h1>Compliance Plans</h1>
        <p class="text-muted mb-0">@companyName</p>
    </div>
</div>

@if (isLoading)
{
    <div class="alert alert-light border">Loading compliance plans...</div>
}
else
{
    <div class="row g-4">
        <div class="col-xl-4">
            <div class="card shadow-sm">
                <div class="card-header bg-white"><h2 class="h5 mb-0">Create Plan</h2></div>
                <div class="card-body">
                    <EditForm Model="model" OnValidSubmit="SaveAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />
                        <div class="mb-3"><label class="form-label">Financial Year</label><InputText class="form-control" @bind-Value="model.FinancialYear" /></div>
                        <div class="mb-3"><label class="form-label">Plan Name</label><InputText class="form-control" @bind-Value="model.PlanName" /></div>
                        <div class="mb-3"><label class="form-label">Template</label><InputSelect class="form-select" @bind-Value="model.ComplianceTemplateId">@foreach (var template in templates){<option value="@template.Id">@template.TemplateName</option>}</InputSelect></div>
                        <div class="row g-3">
                            <div class="col-md-6"><label class="form-label">Start Date</label><InputDate class="form-control" @bind-Value="model.StartDate" /></div>
                            <div class="col-md-6"><label class="form-label">End Date</label><InputDate class="form-control" @bind-Value="model.EndDate" /></div>
                        </div>
                        <div class="mb-3 mt-3"><label class="form-label">AGM Date</label><InputDate class="form-control" @bind-Value="model.AGMDate" /></div>
                        <div class="mb-3"><label class="form-label">Status</label><InputSelect class="form-select" @bind-Value="model.Status">@foreach (var status in CompanyCompliancePlanStatuses.All){<option value="@status">@status</option>}</InputSelect></div>
                        <button type="submit" class="btn btn-primary">Create Plan</button>
                    </EditForm>
                </div>
            </div>
        </div>

        <div class="col-xl-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white"><h2 class="h5 mb-0">Plan Register</h2></div>
                <div class="card-body">
                    @if (plans.Count == 0)
                    {
                        <div class="text-muted">No plans exist yet for this company.</div>
                    }
                    else
                    {
                        @foreach (var plan in plans)
                        {
                            <div class="border rounded-3 p-3 mb-3">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <h3 class="h6 mb-1">@plan.PlanName</h3>
                                        <div class="small text-muted">@plan.FinancialYear | @plan.ComplianceTemplate?.TemplateName</div>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => TogglePlan(plan.Id))">View Work</button>
                                        <button class="btn btn-sm btn-primary" @onclick="@(() => GenerateWorkItemsAsync(plan.Id))">Generate Work Items</button>
                                    </div>
                                </div>
                                <div class="small text-muted mb-3">Start: @plan.StartDate.ToString("dd MMM yyyy") | End: @plan.EndDate.ToString("dd MMM yyyy") | Status: @plan.Status</div>
                                @if (expandedPlanId == plan.Id)
                                {
                                    @if (plan.WorkItems.Count == 0)
                                    {
                                        <div class="text-muted">No work items generated yet.</div>
                                    }
                                    else
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0">
                                                <thead class="table-light"><tr><th>Work Item</th><th>Due Date</th><th>Status</th><th></th></tr></thead>
                                                <tbody>
                                                    @foreach (var workItem in plan.WorkItems.OrderBy(x => x.DueDate))
                                                    {
                                                        var displayStatus = WorkItemHelper.GetDisplayStatus(workItem);
                                                        <tr>
                                                            <td>@workItem.Title</td>
                                                            <td>@(workItem.DueDate?.ToString("dd MMM yyyy") ?? "-")</td>
                                                            <td><span class="badge @BadgeHelper.GetWorkItemStatusBadge(displayStatus)">@displayStatus</span></td>
                                                            <td class="text-end"><a class="btn btn-sm btn-outline-primary" href="/work-items/@workItem.Id">Open</a></td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int CompanyId { get; set; }

    private List<ComplianceTemplate> templates = [];
    private List<CompanyCompliancePlan> plans = [];
    private CompanyCompliancePlan model = new();
    private string companyName = "Company";
    private bool isLoading = true;
    private int expandedPlanId;
    private int firmId;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        var company = await CompanyClientService.GetByIdAsync(CompanyId);
        companyName = company?.CompanyName ?? "Company";
        firmId = company?.FirmId ?? 0;
        templates = await ComplianceTemplateService.GetTemplatesAsync();
        plans = await CompanyCompliancePlanService.GetByCompanyIdAsync(CompanyId);
        model = new CompanyCompliancePlan
        {
            CompanyClientId = CompanyId,
            FirmId = firmId,
            ComplianceTemplateId = templates.FirstOrDefault()?.Id ?? 0,
            FinancialYear = "2025-26",
            PlanName = "Annual Compliance Plan",
            StartDate = new DateOnly(DateTime.Today.Year, 4, 1),
            EndDate = new DateOnly(DateTime.Today.Year + 1, 3, 31),
            Status = CompanyCompliancePlanStatuses.Draft
        };
        isLoading = false;
    }

    private async Task SaveAsync()
    {
        model.CompanyClientId = CompanyId;
        model.FirmId = firmId;
        await CompanyCompliancePlanService.CreatePlanAsync(model);
        await LoadAsync();
    }

    private async Task GenerateWorkItemsAsync(int planId)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Generate work items for this plan? Existing generated work items will not be duplicated.");
        if (!confirmed)
        {
            return;
        }

        await CompanyCompliancePlanService.GenerateWorkItemsFromTemplateAsync(planId);
        plans = await CompanyCompliancePlanService.GetByCompanyIdAsync(CompanyId);
        expandedPlanId = planId;
    }

    private void TogglePlan(int planId)
    {
        expandedPlanId = expandedPlanId == planId ? 0 : planId;
    }
}
